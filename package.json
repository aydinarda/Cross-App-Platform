{
  "name": "cross-app-platform",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "test": "node --test tests/data/*.test.js",
    "test:data": "node --test tests/data/*.test.js",
    "test:dist": "node --test tests/routes/*.test.js",
    "verify": "pnpm check && pnpm test:data && pnpm build && pnpm test:dist",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^5.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
