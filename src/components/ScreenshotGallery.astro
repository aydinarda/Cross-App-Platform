---
import { withBase } from '../lib/url';

interface Props {
  screenshots: string[];
  title: string;
}

const { screenshots, title } = Astro.props;
---

{
  screenshots.length > 0 && (
    <div class="gallery">
      {screenshots.map((src, i) => (
        <a class="shot" href={withBase(src)} target="_blank" rel="noopener">
          <img src={withBase(src)} alt={`${title} screenshot ${i + 1}`} loading="lazy" />
        </a>
      ))}
    </div>
  )
}

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.9rem;
  }
  .shot {
    display: block;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-soft);
    transition: border-color 0.15s ease;
  }
  .shot:hover {
    border-color: var(--accent);
  }
  .shot img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 10;
  }
</style>
