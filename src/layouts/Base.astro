---
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A single showcase for teaching materials produced by UZH - Chair of Sustainable Operations Management.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase('/')}>
        <span class="brand-mark">◆</span>
        <span>App Hub</span>
      </a>
      <nav>
        <a href={withBase('/')}>Apps</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} App Hub — UZH - Chair of Sustainable Operations Management</p>
    </footer>

    <style is:global>
      :root {
        --bg: #0b0e14;
        --bg-soft: #131722;
        --card: #1a1f2e;
        --card-hover: #222838;
        --border: #2a3142;
        --text: #e6e9ef;
        --text-dim: #9aa3b2;
        --accent: #5b8cff;
        --radius: 14px;
        --maxw: 1100px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: radial-gradient(1200px 600px at 50% -200px, #1c2333 0%, var(--bg) 60%);
        color: var(--text);
        font-family:
          ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      main {
        flex: 1;
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 1.1rem 1.25rem;
        width: 100%;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.2px;
      }
      .brand-mark {
        color: var(--accent);
      }

      .site-header nav a {
        color: var(--text-dim);
        font-size: 0.95rem;
      }
      .site-header nav a:hover {
        color: var(--text);
      }

      .site-footer {
        border-top: 1px solid var(--border);
        color: var(--text-dim);
        font-size: 0.85rem;
        text-align: center;
        padding: 1.5rem 1.25rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--text);
        font-weight: 600;
        font-size: 0.92rem;
        cursor: pointer;
        transition:
          background 0.15s ease,
          transform 0.05s ease,
          border-color 0.15s ease;
      }
      .btn:hover {
        background: var(--card-hover);
        border-color: var(--accent);
      }
      .btn:active {
        transform: translateY(1px);
      }
      .btn-primary {
        background: var(--accent);
        border-color: var(--accent);
        color: #0b0e14;
      }
      .btn-primary:hover {
        background: #74a0ff;
        border-color: #74a0ff;
      }

      .badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.18rem 0.5rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        color: var(--text-dim);
      }
      .badge-live {
        color: #34d399;
        border-color: #34d39955;
        background: #34d3991a;
      }
      .badge-beta {
        color: #fbbf24;
        border-color: #fbbf2455;
        background: #fbbf241a;
      }
      .badge-wip {
        color: #f87171;
        border-color: #f8717155;
        background: #f871711a;
      }
    </style>
  </body>
</html>
