---
import { createHash } from 'node:crypto';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A single showcase for teaching materials produced by UZH - Chair of Sustainable Operations Management.' } = Astro.props;
const password = process.env.APP_HUB_PASSWORD ?? '';
const passwordHash = password ? createHash('sha256').update(password).digest('hex') : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      try {
        if (localStorage.getItem('app-hub-auth') === 'ok') {
          document.documentElement.classList.add('auth-ok');
        }
      } catch {
        // Keep the gate visible when browser storage is unavailable.
      }
    </script>
  </head>
  <body>
    <section class="password-gate" aria-label="Password required">
      <form class="password-card" data-password-form data-password-hash={passwordHash}>
        <h1>App Hub</h1>
        <label for="site-password">Password</label>
        <input id="site-password" name="password" type="password" autocomplete="current-password" required />
        <p class="password-error" data-password-error hidden>Wrong password.</p>
        <button class="btn btn-primary" type="submit">Enter</button>
      </form>
    </section>

    <header class="site-header">
      <a class="brand" href={withBase('/')}>
        <span class="brand-mark">◆</span>
        <span>App Hub</span>
      </a>
      <nav>
        <a href={withBase('/')}>Apps</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} App Hub — UZH - Chair of Sustainable Operations Management</p>
    </footer>

    <script is:inline>
      const form = document.querySelector('[data-password-form]');
      const input = document.querySelector('#site-password');
      const error = document.querySelector('[data-password-error]');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!(input instanceof HTMLInputElement) || !(error instanceof HTMLElement)) return;

        const expectedHash = form instanceof HTMLFormElement ? form.dataset.passwordHash : '';
        const actualHash = await sha256(input.value);

        if (expectedHash && actualHash === expectedHash) {
          try {
            localStorage.setItem('app-hub-auth', 'ok');
          } catch {
            // Opening the current page is enough if browser storage is unavailable.
          }
          document.documentElement.classList.add('auth-ok');
          error.hidden = true;
          return;
        }

        error.hidden = false;
        input.value = '';
        input.focus();
      });

      async function sha256(value) {
        const data = new TextEncoder().encode(value);
        const digest = await crypto.subtle.digest('SHA-256', data);
        return [...new Uint8Array(digest)].map((byte) => byte.toString(16).padStart(2, '0')).join('');
      }
    </script>

    <style is:global>
      :root {
        --bg: #0b0e14;
        --bg-soft: #131722;
        --card: #1a1f2e;
        --card-hover: #222838;
        --border: #2a3142;
        --text: #e6e9ef;
        --text-dim: #9aa3b2;
        --accent: #5b8cff;
        --radius: 14px;
        --maxw: 1100px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: radial-gradient(1200px 600px at 50% -200px, #1c2333 0%, var(--bg) 60%);
        color: var(--text);
        font-family:
          ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      html:not(.auth-ok) .site-header,
      html:not(.auth-ok) main,
      html:not(.auth-ok) .site-footer {
        display: none;
      }

      html.auth-ok .password-gate {
        display: none;
      }

      .password-gate {
        flex: 1;
        display: grid;
        place-items: center;
        width: 100%;
        min-height: 100vh;
        padding: 1.25rem;
      }

      .password-card {
        width: min(100%, 340px);
        display: grid;
        gap: 0.75rem;
        padding: 1.5rem;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--card);
      }

      .password-card h1 {
        margin: 0 0 0.35rem;
        font-size: 1.5rem;
      }

      .password-card label {
        color: var(--text-dim);
        font-size: 0.9rem;
        font-weight: 600;
      }

      .password-card input {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--bg-soft);
        color: var(--text);
        font: inherit;
        padding: 0.7rem 0.8rem;
      }

      .password-card input:focus {
        outline: 2px solid #5b8cff66;
        border-color: var(--accent);
      }

      .password-error {
        margin: 0;
        color: #f87171;
        font-size: 0.9rem;
      }

      main {
        flex: 1;
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 1.1rem 1.25rem;
        width: 100%;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.2px;
      }
      .brand-mark {
        color: var(--accent);
      }

      .site-header nav a {
        color: var(--text-dim);
        font-size: 0.95rem;
      }
      .site-header nav a:hover {
        color: var(--text);
      }

      .site-footer {
        border-top: 1px solid var(--border);
        color: var(--text-dim);
        font-size: 0.85rem;
        text-align: center;
        padding: 1.5rem 1.25rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--text);
        font-weight: 600;
        font-size: 0.92rem;
        cursor: pointer;
        transition:
          background 0.15s ease,
          transform 0.05s ease,
          border-color 0.15s ease;
      }
      .btn:hover {
        background: var(--card-hover);
        border-color: var(--accent);
      }
      .btn:active {
        transform: translateY(1px);
      }
      .btn-primary {
        background: var(--accent);
        border-color: var(--accent);
        color: #0b0e14;
      }
      .btn-primary:hover {
        background: #74a0ff;
        border-color: #74a0ff;
      }

      .badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.18rem 0.5rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        color: var(--text-dim);
      }
      .badge-live {
        color: #34d399;
        border-color: #34d39955;
        background: #34d3991a;
      }
      .badge-beta {
        color: #fbbf24;
        border-color: #fbbf2455;
        background: #fbbf241a;
      }
      .badge-wip {
        color: #f87171;
        border-color: #f8717155;
        background: #f871711a;
      }
      /* "down" = temporarily offline — solid red to flag it clearly */
      .badge-down {
        color: #ef4444;
        border-color: #ef444466;
        background: #ef44441f;
      }
      /* "preparation" = announced, not built yet — indigo */
      .badge-preparation {
        color: #818cf8;
        border-color: #818cf855;
        background: #818cf81a;
      }
    </style>
  </body>
</html>
